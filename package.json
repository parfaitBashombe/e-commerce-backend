  "main": "index.js",
  "scripts": {
    "start": "node -r ts-node/regitser/transpile-only -r tsconfig-paths/register ./dist/index.js",
    "dev": "nodemon",
    "build": "tsc -p ts-prod-config.json",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "gen:schema": "cd prisma/ && rm -rf schema.prisma && cd schemas && cat *.prisma >> ../schema.prisma && cd .. && ls && npx prisma format",
    "db:migrate": "prisma migrate dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.10.0",
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/joi": "^17.2.3",
    "@types/node": "^22.15.21",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "dotenv": "^16.5.0",
    "eslint": "^9.27.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.4.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.5.3",
    "prisma": "^6.8.2",
    "tsconfig-paths": "^4.2.0",
